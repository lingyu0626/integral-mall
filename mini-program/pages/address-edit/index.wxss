.page-address-edit {
  min-height: 100vh;
  background: #eceef2;
  padding: 20rpx;
  box-sizing: border-box;
}

.quick-card {
  border-radius: 14rpx;
  background: #f8f8f8;
  padding: 16rpx 16rpx 14rpx;
}

.quick-input {
  width: 100%;
  height: 170rpx;
  font-size: 29rpx;
  color: #333333;
}

.quick-placeholder {
  color: #c0c4cb;
  font-size: 29rpx;
  line-height: 1.45;
}

.quick-btn {
  margin-top: 8rpx;
  margin-left: auto;
  width: 90rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: linear-gradient(90deg, #62deb3 0%, #37ca79 100%);
  color: #ffffff;
  font-size: 27rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.quick-btn::after {
  border: none;
}

.form-card {
  margin-top: 18rpx;
  border-radius: 14rpx;
  background: #f8f8f8;
  padding: 0 18rpx;
}

.row {
  min-height: 96rpx;
  border-bottom: 1rpx solid #e8eaef;
  display: flex;
  align-items: center;
}

.row.no-border {
  border-bottom: none;
}

.label {
  width: 158rpx;
  color: #5d6470;
  font-size: 31rpx;
}

.input {
  flex: 1;
  min-width: 0;
  height: 96rpx;
  line-height: 96rpx;
  color: #333333;
  font-size: 31rpx;
}

.picker-value-wrap {
  flex: 1;
  min-width: 0;
  height: 96rpx;
  display: flex;
  align-items: center;
}

.picker-value {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: left;
  color: #c1c5cc;
  font-size: 31rpx;
  padding-right: 28rpx;
}

.picker-value.picked {
  color: #333333;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(90deg);
  opacity: 0.52;
}

.default-card {
  margin-top: 18rpx;
  border-radius: 14rpx;
  background: #f8f8f8;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.default-label {
  color: #5d6470;
  font-size: 31rpx;
}

.default-switch {
  position: relative;
  width: 112rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #8ea5b1;
  box-sizing: border-box;
}

.default-switch.on {
  background: #33c876;
}

.switch-dot {
  position: absolute;
  left: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffffff;
  transition: left 0.2s ease;
}

.default-switch.on .switch-dot {
  left: 62rpx;
}

.switch-mark {
  position: absolute;
  top: 50%;
  right: 16rpx;
  transform: translateY(-50%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
}

.default-switch.on .switch-mark {
  left: 16rpx;
  right: auto;
}

.save-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 78rpx;
  border-radius: 39rpx;
  background: linear-gradient(90deg, #62deb3 0%, #37ca79 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.save-btn::after {
  border: none;
}
