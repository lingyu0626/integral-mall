.page-home {
  padding: 20rpx 20rpx 24rpx;
}

.hero-swiper {
  height: 284rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.search-bar {
  margin-top: 40rpx;
  margin-bottom: 28rpx;
}

.goods-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.wish-entry {
  margin-top: 0;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 16rpx 18rpx;
}

.wish-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2b3e;
}

.wish-sub {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #7a8698;
}

.goods-item {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 10rpx;
}

.goods-cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 10rpx;
  overflow: hidden;
  background: #eff2f6;
}

.goods-cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.goods-name {
  margin-top: 14rpx;
  font-size: 30rpx;
  color: #27282d;
  font-weight: 600;
  line-height: 1.3;
  height: 40rpx;
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.goods-point {
  margin-top: 8rpx;
  font-size: 36rpx;
}

.empty {
  grid-column: 1 / 3;
  text-align: center;
  color: #9ba0ad;
  padding: 80rpx 0;
}
