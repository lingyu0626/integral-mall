.page-detail {
  min-height: 100vh;
  background: #efefef;
}

.gallery-card {
  position: relative;
  margin: 0 0 12rpx;
}

.banner-swiper {
  width: 100%;
  height: 750rpx;
}

.banner {
  width: 100%;
  height: 750rpx;
  display: block;
}

.pager {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  min-width: 56rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(0, 0, 0, 0.35);
  color: #ffffff;
  font-size: 20rpx;
}

.info-card,
.detail-card {
  background: #ffffff;
  margin-bottom: 12rpx;
  padding: 20rpx 24rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price-value {
  color: #ff2727;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.price-unit {
  margin-left: 4rpx;
  color: #ff2727;
  font-size: 34rpx;
  font-weight: 700;
}

.name {
  margin-top: 20rpx;
  color: #1f1f1f;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.35;
}

.sku-area {
  margin-top: 20rpx;
}

.sku-title {
  color: #666666;
  font-size: 24rpx;
}

.sku-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sku-tag {
  padding: 10rpx 20rpx;
  border-radius: 28rpx;
  background: #f2f4f7;
  color: #333333;
  font-size: 24rpx;
  border: 1rpx solid #e7e9ee;
}

.sku-tag.active {
  background: #e8fff3;
  border-color: #31c778;
  color: #17a55f;
  font-weight: 600;
}

.sku-tag.disabled {
  color: #b6bdc8;
  background: #f5f5f6;
  border-color: #eceef2;
}

.stock-text {
  margin-top: 14rpx;
  color: #7a8291;
  font-size: 24rpx;
}

.section-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
}

.detail-text {
  margin-top: 16rpx;
  color: #555555;
  font-size: 30rpx;
  line-height: 1.7;
  word-break: break-all;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(100rpx + constant(safe-area-inset-bottom));
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding: 0 16rpx constant(safe-area-inset-bottom);
  padding: 0 16rpx env(safe-area-inset-bottom);
  background: #ffffff;
  box-sizing: border-box;
  border-top: 1rpx solid #ececec;
  z-index: 10;
}

.bottom-main {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
}

.bottom-safe-space {
  height: 140rpx;
}

.bar-icon-btn {
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7d8493;
  font-size: 22rpx;
}

.bar-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.exchange-btn {
  flex: 1;
  margin-left: 10rpx;
  height: 74rpx;
  border-radius: 37rpx;
  background: linear-gradient(90deg, #62dcb0 0%, #34cb78 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.exchange-btn::after {
  border: none;
}

.loading {
  text-align: center;
  color: #9ca3b0;
  margin-top: 120rpx;
}
