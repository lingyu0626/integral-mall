.page-points {
  min-height: 100vh;
  background: #f5f5f5;
}

.ledger-list {
  background: #ffffff;
  padding: 0 24rpx;
}

.ledger-item {
  min-height: 130rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border-bottom: 1rpx solid #f2f2f2;
  padding: 18rpx 0;
}

.ledger-item:last-child {
  border-bottom: none;
}

.biz {
  color: #333333;
  font-size: 28rpx;
  line-height: 40rpx;
}

.scene {
  margin-top: 6rpx;
  color: #8e96a5;
  font-size: 22rpx;
}

.detail {
  margin-top: 6rpx;
  color: #52607a;
  font-size: 22rpx;
  line-height: 32rpx;
  word-break: break-all;
}

.time {
  margin-top: 8rpx;
  color: #999999;
  font-size: 22rpx;
}

.remark {
  margin-top: 8rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-all;
}

.left {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.right {
  text-align: right;
  flex-shrink: 0;
}

.amount {
  font-size: 32rpx;
  font-weight: 700;
}

.amount.income {
  color: #2eb86f;
}

.amount.expense {
  color: #ff5b3e;
}

.after {
  margin-top: 8rpx;
  color: #999999;
  font-size: 22rpx;
}

.empty-wrap {
  min-height: calc(100vh - 220rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-image {
  width: 276rpx;
  height: 226rpx;
}

.empty-text {
  margin-top: 22rpx;
  color: #9b9b9b;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  color: #a0a8b8;
  font-size: 22rpx;
  padding: 24rpx 0 12rpx;
}
