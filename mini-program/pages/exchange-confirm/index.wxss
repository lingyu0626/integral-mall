.page-confirm {
  padding: 20rpx;
}

.product-card {
  padding: 16rpx;
  display: flex;
  column-gap: 14rpx;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f1f3f7;
}

.meta {
  flex: 1;
}

.name {
  font-size: 30rpx;
  color: #293140;
  font-weight: 700;
  line-height: 1.4;
}

.point {
  margin-top: 12rpx;
  color: #ff5b3e;
  font-size: 34rpx;
  font-weight: 800;
}

.hint {
  margin-top: 8rpx;
  color: #8f98a8;
  font-size: 22rpx;
}

.sku-block {
  margin-top: 12rpx;
}

.sku-title {
  color: #5f6978;
  font-size: 22rpx;
}

.sku-list {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sku-tag {
  padding: 8rpx 16rpx;
  border-radius: 22rpx;
  background: #f2f4f7;
  color: #394252;
  font-size: 22rpx;
  border: 1rpx solid #e7ebf2;
}

.sku-tag.active {
  background: #e9fff4;
  color: #18a562;
  border-color: #32c778;
  font-weight: 600;
}

.sku-tag.disabled {
  color: #b5bcc9;
  background: #f6f7f8;
  border-color: #eceef2;
}

.section-card {
  margin-top: 16rpx;
  padding: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2e3645;
}

.row {
  margin-top: 8rpx;
  color: #5e6878;
  font-size: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link {
  color: #38c678;
  font-size: 23rpx;
}

.addr-item {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1px solid #e6ebf2;
  background: #fafbfd;
}

.addr-item.active {
  border-color: #38c678;
  background: #f0fbf5;
}

.addr-top {
  display: flex;
  align-items: center;
  column-gap: 10rpx;
}

.addr-name {
  font-size: 26rpx;
  color: #2a3342;
  font-weight: 600;
}

.addr-phone {
  font-size: 24rpx;
  color: #7f8a9a;
}

.default-tag {
  margin-left: auto;
  font-size: 20rpx;
  color: #2eb86f;
  background: #e6f9ee;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.addr-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #5f6978;
}

.empty {
  margin-top: 12rpx;
  color: #9aa3b3;
  font-size: 24rpx;
}

.remark {
  margin-top: 10rpx;
  width: 100%;
  height: 120rpx;
  border-radius: 12rpx;
  border: 1px solid #e6ebf2;
  background: #f8fafc;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 24rpx;
  height: 82rpx;
  border-radius: 41rpx;
  background: #ff5b3e;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.loading {
  margin-top: 120rpx;
  text-align: center;
  color: #9ba2b1;
}
