.profile-page {
  min-height: 100vh;
  background: #eef0f3;
  padding: 16rpx 16rpx 28rpx;
}

.profile-hero {
  margin-top: 0;
}

.profile-card {
  border-radius: 18rpx;
  overflow: hidden;
  background: #ffffff;
}

.user-card {
  background: #e6e8ed;
  padding: 48rpx 32rpx;
}

.user-card-login {
  padding: 40rpx 32rpx;
}

.user-login-tip {
  color: #667084;
  font-size: 28rpx;
}

.wx-login-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  background: #1aad19;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn::after {
  border: none;
}

.user-head {
  display: flex;
  align-items: center;
  column-gap: 32rpx;
}

.avatar-wrap {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f6f7f9;
  flex-shrink: 0;
  border: 1px solid #ffffff;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-meta {
  display: flex;
  flex-direction: column;
  row-gap: 12rpx;
}

.meta-line {
  font-size: 30rpx;
  line-height: 1.4;
  color: #30343d;
}

.meta-value {
  font-weight: 600;
}

.point {
  color: #ff6a55;
  font-weight: 700;
}

.phone-auth-btn {
  margin-top: 10rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #1aad19;
  color: #fff;
  font-size: 24rpx;
  align-self: flex-start;
}

.phone-auth-btn::after {
  border: none;
}

.block-card {
  margin-top: 0;
  border-radius: 0;
  background: #ffffff;
  padding: 24rpx 32rpx 12rpx;
}

.order-card {
  margin-top: 0;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1px solid #edf0f4;
}

.block-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.block-title {
  font-size: 34rpx;
  color: #2c313a;
  font-weight: 600;
}

.block-more {
  font-size: 26rpx;
  color: #b0b6c2;
  padding-right: 0;
}

.block-more::after {
  content: '›';
  margin-left: 4rpx;
}

.order-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 10rpx 0 16rpx;
}

.order-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-badge {
  position: absolute;
  top: -6rpx;
  right: 40rpx;
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 17rpx;
  background: #ff5b3e;
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  border: 1rpx solid #ffffff;
}

.order-icon {
  width: 80rpx;
  height: 80rpx;
}

.order-text {
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #2f343d;
}

.menu-card {
  padding: 10rpx 28rpx 10rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 8rpx 0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  width: 58rpx;
  height: 58rpx;
  margin-right: 24rpx;
}

.menu-title {
  font-size: 34rpx;
  color: #2f343d;
  line-height: 1.25;
}

.menu-arrow {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.55;
}

.menu-item-desc {
  min-height: 84rpx;
  padding: 4rpx 0;
  border-bottom: none;
}

.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(16, 22, 30, 0.52);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 38rpx;
  box-sizing: border-box;
}

.popup-card {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  box-sizing: border-box;
}

.popup-title {
  text-align: center;
  color: #1f2733;
  font-size: 34rpx;
  font-weight: 700;
}

.popup-qr {
  display: block;
  width: 360rpx;
  height: 360rpx;
  margin: 22rpx auto 0;
  border-radius: 12rpx;
  background: #f4f6fa;
}

.popup-tip {
  margin-top: 10rpx;
  text-align: center;
  color: #8a94a6;
  font-size: 22rpx;
}

.popup-close {
  margin-top: 20rpx;
  width: 100%;
  height: 74rpx;
  border-radius: 14rpx;
  background: #1677ff;
  color: #fff;
  font-size: 27rpx;
}

.popup-close::after {
  border: none;
}

.loading {
  margin-top: 40rpx;
  color: #8e97a8;
  text-align: center;
}
