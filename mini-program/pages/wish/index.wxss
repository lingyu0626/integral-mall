.wish-page {
  min-height: 100vh;
  background: #f3f4f7;
  padding: 18rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 14rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2b3f;
}

.sub-title {
  margin-top: 8rpx;
  color: #8a95a9;
  font-size: 23rpx;
  line-height: 1.45;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  margin-bottom: 8rpx;
  color: #5e6b80;
  font-size: 24rpx;
  font-weight: 500;
}

.input,
.textarea {
  width: 100%;
  background: #f6f8fb;
  border-radius: 10rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #2b3442;
  border: 1rpx solid #edf1f6;
}

.input {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 20rpx;
}

.textarea {
  min-height: 190rpx;
  padding: 16rpx 20rpx;
}

.uploader-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.uploader {
  position: relative;
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #dbe2ec;
  background: #fafbfd;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.uploader.has-image {
  border: 2rpx solid #e7ebf2;
}

.uploader-add {
  border-style: dashed;
}

.uploader-placeholder {
  color: #97a2b3;
  font-size: 24rpx;
}

.preview {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.image-actions {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.image-count {
  color: #8f99ab;
  font-size: 22rpx;
}

.remove-text {
  color: #e35e52;
  font-size: 24rpx;
  line-height: 1;
}

.submit-btn::after {
  border: none;
}

.submit-btn {
  margin-top: 20rpx;
  height: 76rpx;
  border-radius: 12rpx;
  background: #1fb86c;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.record {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f7f9fc;
  border: 1rpx solid #edf1f6;
}

.record:last-child {
  margin-bottom: 2rpx;
}

.record-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 600;
  color: #1d2736;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status {
  margin-left: 10rpx;
  font-size: 21rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.status-PENDING {
  color: #b98515;
  background: #fff8e8;
}

.status-APPROVED {
  color: #1fba6d;
  background: #eaf9f1;
}

.status-REJECTED {
  color: #e05f4f;
  background: #fff1ef;
}

.record-msg,
.record-note {
  margin-top: 6rpx;
  color: #5a667a;
  font-size: 24rpx;
  line-height: 1.45;
}

.record-images {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.record-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  background: #f0f3f8;
}

.record-time {
  margin-top: 8rpx;
  color: #97a0ae;
  font-size: 22rpx;
}

.empty {
  text-align: center;
  color: #98a1b0;
  padding: 40rpx 0;
  font-size: 25rpx;
}
