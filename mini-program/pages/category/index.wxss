.page-category {
  min-height: 100vh;
  background: #ffffff;
}

.top-area {
  overflow: hidden;
  background-color: #dbeaf7;
  background-image:
    radial-gradient(circle at 18% 12%, rgba(201, 234, 248, 0.94) 0%, rgba(201, 234, 248, 0) 52%),
    radial-gradient(circle at 85% 22%, rgba(214, 226, 250, 0.9) 0%, rgba(214, 226, 250, 0) 54%),
    linear-gradient(135deg, #d7eaf7 0%, #d9e9f6 52%, #dfe5f4 100%);
}

.custom-nav {
  width: 100%;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-nav-title {
  color: #22324d;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.top-card {
  position: relative;
  margin: 0;
  height: 176rpx;
  overflow: hidden;
  background: transparent;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding-top: 12rpx;
}

.score {
  position: relative;
  z-index: 2;
  padding: 0 32rpx;
  color: #2e6de0;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.14;
}

.score text {
  color: #2568f0;
  margin-left: 12rpx;
}

.quick-row {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  padding: 0 32rpx;
  display: flex;
  gap: 40rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  color: #3f76df;
  font-size: 30rpx;
  font-weight: 600;
}

.quick-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
}

.top-bg {
  position: absolute;
  right: 8rpx;
  bottom: -4rpx;
  width: 338rpx;
  height: 246rpx;
  opacity: 0.9;
}

.search-row {
  margin: -32rpx 24rpx 22rpx;
  position: relative;
  z-index: 10;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.layout {
  height: calc(100vh - 540rpx);
  display: flex;
}

.left {
  width: 170rpx;
  background: #f7f8fa;
}

.cate-item {
  height: 100rpx;
  line-height: 100rpx;
  padding: 0 16rpx;
  text-align: center;
  color: #5e6d82;
  font-size: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cate-item.active {
  background: #ffffff;
  color: #1fb867;
  font-weight: 700;
  position: relative;
}

.cate-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30rpx;
  width: 8rpx;
  height: 40rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: #1ec26f;
}

.right {
  flex: 1;
  background: #ffffff;
  padding: 20rpx 20rpx 0;
  box-sizing: border-box;
}

.right-content {
  padding-bottom: 40rpx;
}

.sort-row {
  display: flex;
  column-gap: 16rpx;
  padding: 0 0 28rpx;
}

.sort-item {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: #f4f6f9;
  color: #7a869a;
  font-size: 24rpx;
}

.sort-item.active {
  background: #1fb86c;
  color: #ffffff;
  font-weight: 600;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 20rpx;
  row-gap: 32rpx;
}

.goods {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f7fa;
}

.cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.name {
  margin-top: 16rpx;
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  height: 40rpx;
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.point {
  margin-top: 8rpx;
  color: #11141b;
  font-size: 40rpx;
  font-weight: 800;
}

.point text {
  font-size: 24rpx;
  color: #8492a6;
  margin-left: 4rpx;
  font-weight: 500;
}

.empty {
  text-align: center;
  color: #9aa1af;
  padding-top: 120rpx;
  font-size: 28rpx;
}
