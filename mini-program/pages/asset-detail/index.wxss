.page-asset-detail {
  padding: 16rpx;
}

.top-card {
  padding: 16rpx;
}

.head {
  display: flex;
  column-gap: 12rpx;
}

.cover {
  width: 170rpx;
  height: 170rpx;
  border-radius: 12rpx;
  background: #f0f2f6;
}

.meta {
  flex: 1;
}

.name {
  color: #2b3443;
  font-size: 30rpx;
  font-weight: 700;
}

.sub {
  margin-top: 6rpx;
  color: #8b95a6;
  font-size: 22rpx;
}

.remark {
  margin-top: 10rpx;
  color: #5f6a79;
  font-size: 22rpx;
}

.use-btn {
  margin-top: 14rpx;
  height: 74rpx;
  border-radius: 37rpx;
  background: #38c678;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.use-btn::after {
  border: none;
}

.flow-card {
  margin-top: 12rpx;
  padding: 14rpx;
}

.title {
  color: #293241;
  font-size: 28rpx;
  font-weight: 700;
}

.flow-item {
  margin-top: 10rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  background: #f8fafc;
}

.flow-main {
  color: #334;
  font-size: 24rpx;
}

.flow-sub,
.flow-time,
.flow-remark {
  margin-top: 4rpx;
  color: #9099a9;
  font-size: 21rpx;
}

.empty,
.loading {
  text-align: center;
  color: #a0a8b8;
  padding: 80rpx 0;
}
