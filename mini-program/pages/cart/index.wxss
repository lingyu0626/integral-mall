.page-cart {
  min-height: 100vh;
  background: #f5f6f8;
}

.filter-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  color: #7f8795;
  font-size: 24rpx;
  box-sizing: border-box;
}

.filter-item {
  line-height: 1;
}

.filter-item.left {
  flex: 1;
  text-align: left;
}

.filter-item.right {
  flex: 1;
  text-align: right;
  font-weight: 600;
}

.empty-wrap {
  margin-top: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 202rpx;
  height: 202rpx;
  opacity: 0.98;
}

.empty-text {
  margin-top: 20rpx;
  color: #9a9fa8;
  font-size: 32rpx;
}

.asset-list {
  padding: 0 16rpx 16rpx;
}

.asset-card {
  margin-top: 12rpx;
  padding: 14rpx;
  background: #ffffff;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.asset-row {
  display: flex;
  column-gap: 12rpx;
}

.cover {
  width: 126rpx;
  height: 126rpx;
  border-radius: 10rpx;
  background: #f0f2f6;
}

.meta {
  flex: 1;
  min-width: 0;
}

.name {
  color: #2a3342;
  font-size: 29rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sub {
  margin-top: 6rpx;
  color: #8b95a6;
  font-size: 22rpx;
}

.asset-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.actions {
  display: flex;
  column-gap: 10rpx;
}

.btn {
  min-width: 100rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background: #38c678;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn.ghost {
  background: #f5f7fa;
  color: #6f7888;
}

.load-more {
  text-align: center;
  color: #a0a8b8;
  font-size: 22rpx;
  padding: 16rpx 0 10rpx;
}

.level-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  z-index: 99;
}

.level-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
}

.level-toolbar {
  height: 86rpx;
  border-top: 1rpx solid #ececec;
  border-bottom: 1rpx solid #ececec;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.toolbar-btn {
  font-size: 30rpx;
  color: #8b8f97;
}

.toolbar-btn.confirm {
  color: #4f98ff;
}

.level-picker {
  height: calc(230rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.picker-item {
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}

.level-picker .picker-item {
  color: #36c776;
}
